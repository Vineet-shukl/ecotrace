# Dependencies
node_modules/
ecotrace/node_modules/

# Build output
ecotrace/dist/

# Firebase
.firebase/
.firebaserc

# Environment / secrets — NEVER commit these
.env
.env.local
.env.*.local
ecotrace/.env
ecotrace/.env.local
ecotrace/.env.*.local

# Allow only the safe committed env files:
!ecotrace/.env.example
!ecotrace/.env.production

# Service account / credentials — NEVER commit these
google-application-credentials.json
service-account*.json
*-service-account.json
*.key.json

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# Logs
*.log
npm-debug.log*

# Temp scripts (Python alternative — keep seed.js as canonical)
seed.py
