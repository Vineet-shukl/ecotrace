# .env.example — Safe template, commit this file.
# Copy to .env (for local dev) and fill in your values.
# .env is gitignored and must NEVER be committed.
#
# Values are available in:
#   Firebase Console → Project Settings → Your apps → SDK setup and config

VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Cloud Run nudge service URL (from gcloud run deploy output)
VITE_NUDGE_SERVICE_URL=https://your-service-hash.region.run.app
